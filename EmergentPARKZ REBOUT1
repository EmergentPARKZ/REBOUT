<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>REBOUT | FPV Operations Platform</title>
<meta name="description" content="REBOUT — Global FPV Operations, RC Racing, Heavy Equipment, Live Events">

<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">

<!-- Google Icons -->
<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

<!-- Firebase SDK -->
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>

<style>
/* ============================================
   REBOUT MASTER STYLES — RWB PATRIOT THEME
   ============================================ */
:root {
  --red: #CC0000;
  --red-bright: #FF1111;
  --red-dark: #880000;
  --white: #FFFFFF;
  --white-dim: #CCCCCC;
  --blue: #003399;
  --blue-bright: #1144FF;
  --blue-dark: #001166;
  --black: #000000;
  --black-soft: #0A0A0A;
  --black-panel: #111111;
  --black-card: #1A1A1A;
  --gold: #FFD700;
  --green: #00FF44;
  --orange: #FF6600;
  --glow-red: 0 0 10px #CC0000, 0 0 20px #CC000066;
  --glow-blue: 0 0 10px #003399, 0 0 20px #00339966;
  --glow-white: 0 0 10px #FFFFFF66;
  --border-red: 1px solid #CC000066;
  --border-blue: 1px solid #00339966;
  --border-white: 1px solid #FFFFFF22;
  --font-main: 'Orbitron', monospace;
  --font-body: 'Rajdhani', sans-serif;
  --font-mono: 'Share Tech Mono', monospace;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: var(--black);
  color: var(--white);
  font-family: var(--font-body);
  font-size: 14px;
  overflow-x: hidden;
  min-height: 100vh;
}

/* ---- SCROLLBAR ---- */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--black-panel); }
::-webkit-scrollbar-thumb { background: var(--red); border-radius: 3px; }

/* ============================================
   TOP COMMAND BAR
   ============================================ */
#topbar {
  background: linear-gradient(90deg, var(--black) 0%, var(--blue-dark) 40%, var(--red-dark) 60%, var(--black) 100%);
  border-bottom: 2px solid var(--red);
  padding: 8px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 1000;
  box-shadow: var(--glow-red);
}

#topbar .logo {
  font-family: var(--font-main);
  font-size: 28px;
  font-weight: 900;
  letter-spacing: 6px;
  background: linear-gradient(90deg, #FF1111, #FFFFFF, #1144FF);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: none;
  cursor: pointer;
}

#topbar .logo span {
  font-size: 11px;
  display: block;
  letter-spacing: 3px;
  background: linear-gradient(90deg, #FF1111, #FFFFFF, #1144FF);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

#topbar .top-controls {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.top-btn {
  background: transparent;
  border: 1px solid var(--white-dim);
  color: var(--white);
  padding: 5px 12px;
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 1px;
  cursor: pointer;
  border-radius: 3px;
  transition: all 0.2s;
  text-transform: uppercase;
}

.top-btn:hover { background: var(--red); border-color: var(--red); box-shadow: var(--glow-red); }
.top-btn.blue:hover { background: var(--blue); border-color: var(--blue); box-shadow: var(--glow-blue); }
.top-btn.active { background: var(--red); border-color: var(--red-bright); }

#clock {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--green);
  letter-spacing: 2px;
  min-width: 80px;
}

#status-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 8px var(--green);
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

/* ============================================
   AD BANNER TOP
   ============================================ */
#ad-top {
  background: linear-gradient(90deg, var(--blue-dark), var(--black-panel), var(--red-dark));
  border-bottom: 1px solid var(--red-dark);
  padding: 6px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 11px;
  color: var(--white-dim);
}

#ad-top .ad-slot {
  background: var(--black-card);
  border: 1px solid var(--gold);
  padding: 4px 16px;
  border-radius: 2px;
  font-family: var(--font-mono);
  color: var(--gold);
  font-size: 10px;
  letter-spacing: 2px;
}

/* ============================================
   TICKER TAPE
   ============================================ */
#ticker {
  background: var(--red-dark);
  border-bottom: 1px solid var(--red);
  padding: 5px 0;
  overflow: hidden;
  white-space: nowrap;
}

#ticker-inner {
  display: inline-block;
  animation: ticker 40s linear infinite;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--white);
  letter-spacing: 1px;
}

@keyframes ticker {
  0% { transform: translateX(100vw); }
  100% { transform: translateX(-100%); }
}

/* ============================================
   MAIN LAYOUT — 3 COLUMNS
   ============================================ */
#main-layout {
  display: grid;
  grid-template-columns: 220px 1fr 220px;
  gap: 0;
  min-height: calc(100vh - 120px);
}

/* ============================================
   LEFT PANEL
   ============================================ */
#left-panel {
  background: var(--black-panel);
  border-right: var(--border-red);
  padding: 12px 8px;
  overflow-y: auto;
  max-height: calc(100vh - 120px);
}

.panel-title {
  font-family: var(--font-main);
  font-size: 10px;
  letter-spacing: 3px;
  color: var(--red);
  text-transform: uppercase;
  padding: 6px 8px;
  border-bottom: var(--border-red);
  margin-bottom: 8px;
}

.agent-category {
  margin-bottom: 6px;
}

.agent-cat-header {
  background: var(--black-card);
  border: var(--border-red);
  border-left: 3px solid var(--red);
  padding: 7px 10px;
  cursor: pointer;
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1px;
  color: var(--white);
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.2s;
  text-transform: uppercase;
}

.agent-cat-header:hover { background: var(--red-dark); border-left-color: var(--red-bright); }
.agent-cat-header.active { background: var(--red-dark); border-left-color: var(--gold); color: var(--gold); }

.agent-list {
  display: none;
  background: var(--black);
  border: var(--border-red);
  border-top: none;
}

.agent-list.open { display: block; }

.agent-item {
  padding: 6px 14px;
  font-size: 11px;
  color: var(--white-dim);
  cursor: pointer;
  border-bottom: 1px solid #1A1A1A;
  transition: all 0.15s;
  font-family: var(--font-body);
  display: flex;
  align-items: center;
  gap: 6px;
}

.agent-item:hover { background: var(--blue-dark); color: var(--white); padding-left: 20px; }
.agent-item .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
.agent-item .dot.red { background: var(--red); }
.agent-item .dot.yellow { background: var(--gold); }

/* ============================================
   CENTER PANEL
   ============================================ */
#center-panel {
  background: var(--black-soft);
  overflow-y: auto;
  max-height: calc(100vh - 120px);
}

/* Camera Mosaic */
#camera-section {
  padding: 10px;
  border-bottom: var(--border-red);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.section-title {
  font-family: var(--font-main);
  font-size: 11px;
  letter-spacing: 3px;
  color: var(--red);
  text-transform: uppercase;
}

.view-controls {
  display: flex;
  gap: 4px;
}

.view-btn {
  background: var(--black-card);
  border: var(--border-white);
  color: var(--white-dim);
  padding: 3px 8px;
  font-size: 10px;
  cursor: pointer;
  border-radius: 2px;
  font-family: var(--font-body);
  font-weight: 600;
  letter-spacing: 1px;
  transition: all 0.2s;
}

.view-btn:hover, .view-btn.active { background: var(--red); border-color: var(--red); color: var(--white); }

#camera-mosaic {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 4px;
}

.camera-cell {
  background: var(--black);
  border: 1px solid #222;
  aspect-ratio: 16/9;
  position: relative;
  cursor: pointer;
  overflow: hidden;
  transition: border-color 0.2s;
}

.camera-cell:hover { border-color: var(--red); }
.camera-cell.active { border-color: var(--gold); box-shadow: 0 0 8px var(--gold); }
.camera-cell.fullscreen { grid-column: 1 / -1; grid-row: 1 / 3; }

.camera-feed {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background: repeating-linear-gradient(
    45deg,
    #0A0A0A,
    #0A0A0A 10px,
    #111 10px,
    #111 20px
  );
}

.camera-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 6px;
  pointer-events: none;
}

.cam-label {
  background: rgba(0,0,0,0.8);
  border: 1px solid var(--red);
  padding: 2px 6px;
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--red);
  letter-spacing: 1px;
  align-self: flex-start;
}

.cam-status {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.cam-signal {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--green);
  background: rgba(0,0,0,0.8);
  padding: 2px 5px;
}

.cam-fps {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--gold);
  background: rgba(0,0,0,0.8);
  padding: 2px 5px;
}

.no-signal {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  color: #333;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 2px;
}

/* Command Terminal */
#command-section {
  padding: 10px;
  border-bottom: var(--border-blue);
}

#terminal {
  background: var(--black);
  border: 1px solid #1A3300;
  padding: 8px;
  height: 120px;
  overflow-y: auto;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--green);
  margin-bottom: 8px;
  border-radius: 2px;
}

.terminal-line { margin-bottom: 2px; line-height: 1.4; }
.terminal-line .ts { color: #446644; margin-right: 6px; }
.terminal-line .cmd { color: var(--green); }
.terminal-line .err { color: var(--red); }
.terminal-line .warn { color: var(--gold); }
.terminal-line .info { color: var(--blue-bright); }

#command-input-row {
  display: flex;
  gap: 6px;
}

#command-input {
  flex: 1;
  background: var(--black);
  border: 1px solid var(--blue);
  color: var(--green);
  padding: 6px 10px;
  font-family: var(--font-mono);
  font-size: 12px;
  border-radius: 2px;
  outline: none;
}

#command-input:focus { border-color: var(--green); box-shadow: 0 0 6px #00FF4444; }

.cmd-btn {
  background: var(--blue-dark);
  border: 1px solid var(--blue);
  color: var(--white);
  padding: 6px 12px;
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
  border-radius: 2px;
  letter-spacing: 1px;
  transition: all 0.2s;
}

.cmd-btn:hover { background: var(--blue); box-shadow: var(--glow-blue); }

/* Quick Commands */
#quick-commands {
  padding: 8px 10px;
  border-bottom: var(--border-red);
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.quick-btn {
  background: var(--black-card);
  border: var(--border-white);
  color: var(--white-dim);
  padding: 4px 10px;
  font-size: 10px;
  font-family: var(--font-body);
  font-weight: 700;
  letter-spacing: 1px;
  cursor: pointer;
  border-radius: 2px;
  transition: all 0.2s;
  text-transform: uppercase;
}

.quick-btn:hover { background: var(--blue-dark); border-color: var(--blue); color: var(--white); }
.quick-btn.red { border-color: var(--red-dark); }
.quick-btn.red:hover { background: var(--red-dark); border-color: var(--red); }

/* Telemetry Bar */
#telemetry-bar {
  padding: 8px 10px;
  background: var(--black-panel);
  border-bottom: var(--border-blue);
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 6px;
}

.tele-item {
  background: var(--black);
  border: var(--border-blue);
  padding: 5px 8px;
  border-radius: 2px;
  text-align: center;
}

.tele-label {
  font-family: var(--font-mono);
  font-size: 8px;
  color: var(--blue-bright);
  letter-spacing: 1px;
  display: block;
  margin-bottom: 2px;
}

.tele-value {
  font-family: var(--font-mono);
  font-size: 14px;
  color: var(--white);
  font-weight: bold;
}

.tele-value.green { color: var(--green); }
.tele-value.red { color: var(--red); }
.tele-value.gold { color: var(--gold); }

/* Participant + Chat */
#social-section {
  padding: 10px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.social-box {
  background: var(--black);
  border: var(--border-white);
  border-radius: 2px;
  overflow: hidden;
}

.social-box-header {
  background: var(--black-card);
  padding: 5px 10px;
  font-family: var(--font-main);
  font-size: 9px;
  letter-spacing: 2px;
  color: var(--red);
  border-bottom: var(--border-red);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.social-box-body {
  padding: 6px;
  height: 140px;
  overflow-y: auto;
}

.participant-item {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 4px;
  border-bottom: 1px solid #111;
  font-size: 11px;
  color: var(--white-dim);
}

.participant-item .role-badge {
  font-size: 8px;
  padding: 1px 4px;
  border-radius: 2px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.role-badge.admin { background: var(--gold); color: var(--black); }
.role-badge.operator { background: var(--red); color: var(--white); }
.role-badge.camera { background: var(--blue); color: var(--white); }
.role-badge.spectator { background: #333; color: var(--white-dim); }
.role-badge.judge { background: var(--orange); color: var(--white); }

.chat-message {
  padding: 3px 4px;
  border-bottom: 1px solid #111;
  font-size: 11px;
  line-height: 1.4;
}

.chat-name { color: var(--red); font-weight: 700; margin-right: 4px; }
.chat-text { color: var(--white-dim); }

.chat-input-row {
  display: flex;
  border-top: var(--border-white);
}

.chat-input {
  flex: 1;
  background: var(--black);
  border: none;
  color: var(--white);
  padding: 5px 8px;
  font-family: var(--font-body);
  font-size: 11px;
  outline: none;
}

.chat-send {
  background: var(--red-dark);
  border: none;
  color: var(--white);
  padding: 5px 10px;
  cursor: pointer;
  font-size: 11px;
  font-weight: 700;
  transition: background 0.2s;
}

.chat-send:hover { background: var(--red); }

/* ============================================
   RIGHT PANEL
   ============================================ */
#right-panel {
  background: var(--black-panel);
  border-left: var(--border-blue);
  padding: 12px 8px;
  overflow-y: auto;
  max-height: calc(100vh - 120px);
}

/* Leaderboard */
.leaderboard-item {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 5px 6px;
  border-bottom: 1px solid #1A1A1A;
  font-size: 11px;
  transition: background 0.15s;
  cursor: pointer;
}

.leaderboard-item:hover { background: var(--blue-dark); }

.lb-rank {
  font-family: var(--font-mono);
  font-size: 12px;
  font-weight: bold;
  min-width: 20px;
  text-align: center;
}

.lb-rank.gold { color: var(--gold); }
.lb-rank.silver { color: #AAAAAA; }
.lb-rank.bronze { color: #CD7F32; }

.lb-name { flex: 1; color: var(--white); font-weight: 600; }
.lb-score { font-family: var(--font-mono); color: var(--green); font-size: 11px; }
.lb-vehicle { font-size: 9px; color: var(--white-dim); }

/* Portal Links */
.portal-link {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 8px;
  margin-bottom: 4px;
  background: var(--black-card);
  border: var(--border-white);
  border-left: 3px solid var(--blue);
  cursor: pointer;
  transition: all 0.2s;
  border-radius: 2px;
}

.portal-link:hover { background: var(--blue-dark); border-left-color: var(--blue-bright); }
.portal-link .portal-icon { font-size: 16px; }
.portal-link .portal-text { font-size: 11px; font-weight: 700; letter-spacing: 1px; color: var(--white); text-transform: uppercase; }
.portal-link .portal-sub { font-size: 9px; color: var(--white-dim); }

/* Emergency Stop */
#emergency-stop {
  background: linear-gradient(135deg, var(--red-dark), #440000);
  border: 2px solid var(--red);
  padding: 12px;
  text-align: center;
  cursor: pointer;
  margin-bottom: 8px;
  border-radius: 3px;
  transition: all 0.2s;
  animation: emergency-pulse 2s infinite;
}

#emergency-stop:hover {
  background: var(--red);
  box-shadow: var(--glow-red);
  transform: scale(1.02);
}

@keyframes emergency-pulse {
  0%, 100% { box-shadow: 0 0 5px var(--red); }
  50% { box-shadow: 0 0 20px var(--red), 0 0 40px var(--red-dark); }
}

#emergency-stop .e-icon { font-size: 24px; display: block; }
#emergency-stop .e-text { font-family: var(--font-main); font-size: 11px; letter-spacing: 3px; color: var(--white); }

/* Event Info Box */
.event-info-box {
  background: var(--black);
  border: var(--border-gold, 1px solid var(--gold));
  padding: 8px;
  margin-bottom: 8px;
  border-radius: 2px;
}

.event-name {
  font-family: var(--font-main);
  font-size: 11px;
  color: var(--gold);
  letter-spacing: 2px;
  margin-bottom: 4px;
}

.event-detail {
  font-size: 10px;
  color: var(--white-dim);
  line-height: 1.6;
  font-family: var(--font-mono);
}

/* ============================================
   FOOTER
   ============================================ */
#footer {
  background: var(--black-panel);
  border-top: 2px solid var(--blue);
  padding: 10px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 10px;
  color: var(--white-dim);
  font-family: var(--font-mono);
}

#footer .footer-logo {
  font-family: var(--font-main);
  font-size: 14px;
  font-weight: 900;
  background: linear-gradient(90deg, #FF1111, #FFFFFF, #1144FF);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4px;
}

#footer .footer-links { display: flex; gap: 16px; }
#footer .footer-links a { color: var(--white-dim); text-decoration: none; transition: color 0.2s; }
#footer .footer-links a:hover { color: var(--red); }

/* ============================================
   MODALS
   ============================================ */
.modal-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.92);
  z-index: 2000;
  align-items: center;
  justify-content: center;
}

.modal-overlay.active { display: flex; }

.modal-box {
  background: var(--black-panel);
  border: 1px solid var(--red);
  box-shadow: var(--glow-red);
  width: 90%;
  max-width: 600px;
  max-height: 85vh;
  overflow-y: auto;
  border-radius: 4px;
  animation: modalIn 0.2s ease;
}

@keyframes modalIn {
  from { transform: scale(0.95); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal-header {
  background: linear-gradient(90deg, var(--red-dark), var(--black-card));
  padding: 12px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: var(--border-red);
}

.modal-title {
  font-family: var(--font-main);
  font-size: 14px;
  letter-spacing: 3px;
  color: var(--white);
  text-transform: uppercase;
}

.modal-close {
  background: none;
  border: 1px solid var(--white-dim);
  color: var(--white);
  width: 28px; height: 28px;
  cursor: pointer;
  font-size: 16px;
  border-radius: 2px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.modal-close:hover { background: var(--red); border-color: var(--red); }

.modal-body { padding: 16px; }

/* Form Styles */
.form-group { margin-bottom: 14px; }
.form-label {
  display: block;
  font-family: var(--font-mono);
  font-size: 10px;
  color: var(--blue-bright);
  letter-spacing: 2px;
  margin-bottom: 5px;
  text-transform: uppercase;
}

.form-input, .form-select {
  width: 100%;
  background: var(--black);
  border: 1px solid #333;
  color: var(--white);
  padding: 8px 12px;
  font-family: var(--font-body);
  font-size: 13px;
  border-radius: 2px;
  outline: none;
  transition: border-color 0.2s;
}

.form-input:focus, .form-select:focus { border-color: var(--red); }
.form-select option { background: var(--black-panel); }

.form-btn {
  background: var(--red-dark);
  border: 1px solid var(--red);
  color: var(--white);
  padding: 10px 20px;
  font-family: var(--font-main);
  font-size: 11px;
  letter-spacing: 2px;
  cursor: pointer;
  border-radius: 2px;
  width: 100%;
  transition: all 0.2s;
  text-transform: uppercase;
}

.form-btn:hover { background: var(--red); box-shadow: var(--glow-red); }
.form-btn.blue { background: var(--blue-dark); border-color: var(--blue); }
.form-btn.blue:hover { background: var(--blue); box-shadow: var(--glow-blue); }

.google-btn {
  background: var(--white);
  border: none;
  color: var(--black);
  padding: 10px 20px;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  border-radius: 3px;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  transition: all 0.2s;
  margin-bottom: 10px;
}

.google-btn:hover { background: #F0F0F0; box-shadow: 0 2px 8px rgba(255,255,255,0.3); }

.divider {
  text-align: center;
  color: #444;
  font-size: 11px;
  margin: 12px 0;
  position: relative;
}

.divider::before, .divider::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 40%;
  height: 1px;
  background: #333;
}

.divider::before { left: 0; }
.divider::after { right: 0; }

/* Emergency Modal */
#emergency-modal .modal-box { border-color: var(--red); }
#emergency-modal .modal-header { background: var(--red-dark); }

.emergency-content {
  text-align: center;
  padding: 20px;
}

.emergency-icon { font-size: 64px; display: block; margin-bottom: 12px; }

.emergency-title {
