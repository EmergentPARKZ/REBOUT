  border: 1px solid #444;
  color: var(--white-dim);
  padding: 8px 20px;
  font-family: var(--font-body);
  font-size: 12px;
  cursor: pointer;
  border-radius: 2px;
  width: 100%;
  transition: all 0.2s;
