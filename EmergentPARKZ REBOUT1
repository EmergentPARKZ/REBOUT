.modal-tab:hover { color: var(--white); }
.modal-tab.active { color: var(--red); border-bottom-color: var(--red); }

.tab-content { display: none; }
.tab-content.active { display: block; }

/* Grid cards */
.card-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
  margin-bottom: 12px;
}

.info-card {
