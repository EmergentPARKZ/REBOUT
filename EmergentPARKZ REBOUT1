.ad-banner.sponsor { border-color: var(--gold); color: var(--gold); }

/* ============================================
   NOTIFICATION TOAST
   ============================================ */
#toast-container {
  position: fixed;
  bottom: 20px;
  right: 20px;
  z-index: 3000;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.toast {
  background: var(--black-panel);
  border-left: 3px solid var(--green);
  padding: 10px 14px;
  font-size: 12px;
  color: var(--white);
  border-radius: 2px;
