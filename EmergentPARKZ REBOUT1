.info-card:hover { border-color: var(--red); background: var(--black-card); }
.info-card .card-icon { font-size: 20px; margin-bottom: 4px; }
.info-card .card-title { font-family: var(--font-main); font-size: 10px; color: var(--white); letter-spacing: 1px; }
.info-card .card-sub { font-size: 10px; color: var(--white-dim); margin-top: 2px; }

/* ============================================
   AD BANNER BOTTOM
   ============================================ */
#ad-bottom {
