}

.toast.error { border-left-color: var(--red); }
.toast.warn { border-left-color: var(--gold); }
.toast.info { border-left-color: var(--blue-bright); }

@keyframes toastIn {
  from { transform: translateX(100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

/* ============================================
